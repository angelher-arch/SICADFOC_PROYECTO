# Postgres database configuration for Render
# PRIORIDAD 1: DATABASE_URL (Render Cloud)
DATABASE_URL=postgresql://user:password@host:port/database

# Opcional: entorno local o cloud explícito
ENVIRONMENT=local

# Fallback local database configuration
DB_NAME=FOC26DB
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_HOST=localhost
DB_PORT=5432

# Pooling de conexiones SQLAlchemy
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# Admin defaults (set these in Render environment variables)
ADMIN_CEDULA=V-00000000
ADMIN_EMAIL=admin@iujo.edu
ADMIN_LOGIN=admin
ADMIN_PASSWORD=change_me
ADMIN_ROLE=Admin

# URL base pública opcional si tu app necesita rutas absolutas
APP_BASE_URL=https://tu-app.onrender.com

# Variables opcionales de seguridad si tu aplicación las consume
JWT_SECRET=replace_with_secure_value
API_KEY=replace_with_secure_value

# Debug mode for local development
DEBUG_MODE=False
