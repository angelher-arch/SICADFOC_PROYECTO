# Variables de entorno para SICADFOC - CONFIGURACIÓN DUAL
# Copie este archivo a .env y complete con sus valores

# ============================================================================
# CONFIGURACIÓN AUTOMÁTICA (Prioridad 1)
# ============================================================================
# Si DATABASE_URL existe, el sistema usa Render (producción)
# Si no existe, el sistema usa localhost (desarrollo)

# Base de datos Render (producción) - PRIORIDAD 1
# Esta variable tiene prioridad sobre las demás configuraciones locales
# Si está configurada, el sistema se conectará a Render automáticamente
DATABASE_URL=postgresql://usuario:password@host:puerto/database?sslmode=require

# ============================================================================
# CONFIGURACIÓN LOCAL (Prioridad 2 - Fallback)
# ============================================================================
# Estas variables se usan solo si DATABASE_URL no está configurado
# El sistema automáticamente usará estas credenciales locales

# Base de datos local (opcional - usa valores por defecto si no se especifica)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=FOC26
DB_USER=postgres
DB_PASSWORD=Beba36*ad514xa

# ============================================================================
# SINCRONIZACIÓN LOCAL -> NUBE (Solo para desarrollo local)
# ============================================================================
# Esta variable se usa solo para sincronizar datos desde local hacia Render
# Configure esto solo cuando necesite sincronizar su base de datos local

# Base de datos Render para sincronización (solo en entorno local)
# Use el mismo valor que DATABASE_URL pero con diferente nombre de variable
RENDER_DATABASE_URL=postgresql://usuario:password@host:puerto/database?sslmode=require

# ============================================================================
# CONFIGURACIÓN ADICIONAL (Opcional)
# ============================================================================
ENVIRONMENT=development
DEBUG=false

# ============================================================================
# NOTAS DE USO:
# ============================================================================
# 1. Para desarrollo local: NO configure DATABASE_URL
#    - El sistema usará automáticamente las credenciales locales
#
# 2. Para producción en Render: Configure DATABASE_URL
#    - El sistema usará automáticamente la base de datos de Render
#
# 3. Para sincronización local -> nube:
#    - Configure RENDER_DATABASE_URL (solo en entorno local)
#    - Use el botón "🚀 Sincronizar Base de Datos" en Configuración
#
# 4. El sistema detecta automáticamente el entorno y nunca falla al arrancar
