# SICADFOC 2026 - Variables de Entorno - Archivo de Ejemplo
# Copia este archivo a .env y completa los valores reales

# =============================================================================
# BASE DE DATOS POSTGRESQL (Render)
# =============================================================================
DATABASE_URL=postgresql://username:password@host:port/database_name
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sicadfoc
DB_USER=sicadfoc_user
DB_PASSWORD=your_password_here

# =============================================================================
# CONFIGURACIÓN DE CORREO SMTP
# =============================================================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-16-character-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=SICADFOC 2026

# =============================================================================
# SEGURIDAD DE LA APLICACIÓN
# =============================================================================
SECRET_KEY=generate-a-very-long-random-string-here-min-32-chars
JWT_SECRET_KEY=another-long-random-string-for-jwt-tokens
SESSION_SECRET=session-secret-key-here

# =============================================================================
# CONFIGURACIÓN DE STREAMLIT
# =============================================================================
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_BROWSER_GATHER_USAGE_STATS=false

# =============================================================================
# CONFIGURACIÓN DE RENDER
# =============================================================================
RENDER_DEPLOY_HOOK_URL=https://api.render.com/deploy/srv-xxxxx?key=xxxxx
RENDER_EXTERNAL_URL=https://sicadfoc-app.onrender.com
RENDER_SERVICE_ID=sicadfoc-app

# =============================================================================
# CONFIGURACIÓN DE LA APLICACIÓN
# =============================================================================
APP_NAME=SICADFOC 2026
APP_VERSION=2.0.0
APP_ENVIRONMENT=production
APP_DEBUG=false

# =============================================================================
# CONFIGURACIÓN DE ARCHIVOS Y RUTAS
# =============================================================================
UPLOAD_PATH=/app/uploads
LOG_PATH=/app/logs
BACKUP_PATH=/app/backups

# =============================================================================
# CONFIGURACIÓN DE CORREO EN PRODUCCIÓN
# =============================================================================
EMAIL_HOST_USER=your-production-email@gmail.com
EMAIL_HOST_PASSWORD=your-production-app-password
DEFAULT_FROM_EMAIL=noreply@sicadfoc.edu.ve

# =============================================================================
# CONFIGURACIÓN DE MONITOREO (Opcional)
# =============================================================================
SENTRY_DSN=your-sentry-dsn-here
LOG_LEVEL=INFO

# =============================================================================
# INSTRUCCIONES:
# =============================================================================
# 1. Copia este archivo: cp .env.example .env
# 2. Edita .env con tus valores reales
# 3. NUNCA subas .env a GitLab (ya está en .gitignore)
# 4. Configura las mismas variables en el panel de Render
# 5. Para generar SECRET_KEY: python -c "import secrets; print(secrets.token_urlsafe(32))"
